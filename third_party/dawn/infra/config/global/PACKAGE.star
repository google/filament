"""Package declaration for the Dawn project."""

pkg.declare(
    name = "@dawn-project",
    lucicfg = "1.45.6",
)

pkg.options.lint_checks([
    "all",
])

pkg.entrypoint("main.star")

pkg.depend(
    name = "@chromium-luci",
    source = pkg.source.googlesource(
        host = "chromium",
        repo = "infra/chromium",
        ref = "refs/heads/main",
        path = "starlark-libs/chromium-luci",
        revision = "107593a04e0004d196a752d184cc107f305e4d77",
    ),
)

pkg.depend(
    name = "@chromium-targets",
    source = pkg.source.googlesource(
        host = "chromium",
        repo = "chromium/src",
        ref = "refs/heads/main",
        path = "infra/config/targets",
        revision = "c8fb3065f8298a1e27cb02493463609c90f556d9",
    ),
)

pkg.resources([
    "milestones.json",
])
