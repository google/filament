    "${dawn_root}/include/dawn/replay/Replay.h",
    "${dawn_root}/include/dawn/replay/dawn_replay_export.h",
    "BlitBufferToDepthTexture.cpp",
    "BlitBufferToDepthTexture.h",
    "Capture.cpp",
    "Capture.h",
    "CaptureWalker.cpp",
    "CaptureWalker.h",
    "Deserialization.cpp",
    "Deserialization.h",
    "Error.cpp",
    "Error.h",
    "ReadHead.cpp",
    "ReadHead.h",
    "Replay.cpp",
    "ReplayImpl.h",
  ]

  deps = [
    "${dawn_root}/include/dawn:cpp_headers",
    "${dawn_root}/src/dawn:proc",
    "${dawn_root}/src/dawn:serialization",
    "${dawn_root}/src/dawn/common",
  ]

  public_deps = [ "${dawn_root}:abseil" ]
}
