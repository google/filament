#version 450
layout(local_size_x=64) in;
layout(std430,binding=0) writeonly buffer D { float dst[]; };
layout(std430,binding=1) readonly buffer S { float src[]; };
layout(push_constant) uniform PC { uint n,ch; float m0,m1,m2,m3,m4,m5,m6,m7,m8; } p;
void main(){
  uint i=gl_GlobalInvocationID.x; if(i>=p.n) return; uint b=i*p.ch;
  float r=src[b], g=(p.ch>1u)?src[b+1u]:0.0, bl=(p.ch>2u)?src[b+2u]:0.0;
  dst[b]=p.m0*r+p.m1*g+p.m2*bl;
  if(p.ch>1u) dst[b+1u]=p.m3*r+p.m4*g+p.m5*bl;
  if(p.ch>2u) dst[b+2u]=p.m6*r+p.m7*g+p.m8*bl;
  for(uint c=3u;c<p.ch;c++) dst[b+c]=src[b+c];
}
