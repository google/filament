#version 450
layout(local_size_x=64) in;
layout(std430,binding=0) readonly buffer S { uint src[]; };
layout(std430,binding=1) writeonly buffer D { uint dst[]; };
layout(push_constant) uniform PC { uint n; } p;
uint gb(uint i){ return (src[i>>2] >> ((i&3u)*8u)) & 0xffu; }
void main(){
  uint w=gl_GlobalInvocationID.x; uint nbytes=p.n; uint nwords=(nbytes+3u)>>2; if(w>=nwords) return;
  uint halfp=(nbytes+1u)>>1; uint outw=0u;
  for(uint t=0u;t<4u;t++){ uint i=w*4u+t; if(i>=nbytes) break;
    uint b=((i&1u)==1u)? gb(halfp+(i>>1)) : gb(i>>1); outw|=(b<<(t*8u)); }
  dst[w]=outw;
}
