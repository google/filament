#version 450
layout(local_size_x=64) in;
layout(std430,binding=0) readonly buffer S { uint inb[]; };
layout(std430,binding=1) readonly buffer O { uint offs[]; };
layout(std430,binding=2) buffer D { uint outb[]; };
layout(push_constant) uniform PC { uint n,tile,nblk; } p;
uint gb(uint i){ return (inb[i>>2] >> ((i&3u)*8u)) & 0xffu; }
void sb(uint i, uint v){ uint wi=i>>2; uint sh=(i&3u)*8u; outb[wi]=(outb[wi]&~(0xffu<<sh))|((v&0xffu)<<sh); }
void main(){
  uint blk=gl_GlobalInvocationID.x; if(blk>=p.nblk) return;
  uint s=blk*p.tile; uint e=min(s+p.tile,p.n); int acc=int(offs[blk]);
  for(uint i=s;i<e;i++){ int q=(i==0u)?int(gb(0u)):(int(gb(i))-128); acc=(acc+q)&0xff; sb(i,uint(acc)); }
}
