/*
 * TinyEXR - CUDA kernels for the GPU backend, embedded as an NVRTC source
 * string. Included only inside the EXR_USE_CUDA block of exr_gpu_cuda.c.
 *
 * Bit-exactness: the lossless reconstruction kernels (predictor / interleave /
 * byte channel copies) use only integer/byte arithmetic mod 256, matching the
 * scalar reference in exr_codec.c exactly. half<->float uses the standard IEEE
 * bit manipulation (half->float is exact; float->half is round-to-nearest-even).
 * The float math kernels (resize/color/tonemap/transfer/lut) are compared with
 * tolerance, not bit-exactly.
 *
 * Copyright (c) 2014-2026 Syoyo Fujita and TinyEXR authors
 * SPDX-License-Identifier: BSD-3-Clause
 */

static const char *EXR_GPU_KERNEL_SRC =
/* ---- type codes (must match exr_pixel_type): 0=UINT 1=HALF 2=FLOAT ---- */
"typedef unsigned char u8;\n"
"typedef unsigned short u16;\n"
"typedef unsigned int u32;\n"
"\n"
/* ===== half <-> float (bit-exact / RNE) ================================ */
"__device__ __forceinline__ float exrg_half_to_float(u16 h){\n"
"  u32 s=(u32)(h>>15)&1u, e=(u32)(h>>10)&0x1fu, m=(u32)h&0x3ffu, out;\n"
"  if(e==0u){\n"
"    if(m==0u){ out=s<<31; }\n"
"    else { e=127u-15u+1u; while((m&0x400u)==0u){ m<<=1; e--; } m&=0x3ffu;\n"
"           out=(s<<31)|(e<<23)|(m<<13); }\n"
"  } else if(e==0x1fu){ out=(s<<31)|(0xffu<<23)|(m<<13); }\n"
"  else { out=(s<<31)|((e-15u+127u)<<23)|(m<<13); }\n"
"  return __uint_as_float(out);\n"
"}\n"
"__device__ __forceinline__ u16 exrg_float_to_half(float f){\n"
"  u32 x=__float_as_uint(f);\n"
"  u32 s=(x>>16)&0x8000u; int e=(int)((x>>23)&0xffu)-127+15; u32 m=x&0x7fffffu;\n"
"  if(((x>>23)&0xffu)==0xffu){ return (u16)(s|(m?0x7e00u:0x7c00u)); }\n"
"  if(e>=0x1f){ return (u16)(s|0x7c00u); }\n"
"  if(e<=0){\n"
"    if(e<-10) return (u16)s;\n"
"    m|=0x800000u; int sh=14-e; u32 hf=m>>sh; u32 rem=m&(((u32)1<<sh)-1u);\n"
"    u32 half=(u32)1<<(sh-1);\n"
"    if(rem>half || (rem==half && (hf&1u))) hf++;\n"
"    return (u16)(s|hf);\n"
"  }\n"
"  u32 hf=((u32)e<<10)|(m>>13); u32 rem=m&0x1fffu;\n"
"  if(rem>0x1000u || (rem==0x1000u && (hf&1u))) hf++;\n"
"  return (u16)(s|hf);\n"
"}\n"
"\n"
/* ===== reconstruction: predictor decode (3-pass segmented scan) ========= */
/* qval(i) = (i==0)? p[0] : p[i]-128 ; decoded = inclusive prefix sum mod 256. */
"extern \"C\" __global__ void exrg_pred_partials(const u8* p, int n, int tile, int* partials){\n"
"  int blk=blockIdx.x; long s=(long)blk*tile; long e=s+tile; if(e>n) e=n;\n"
"  int acc=0; for(long i=s;i<e;i++){ int q=(i==0)?(int)p[0]:((int)p[i]-128); acc=(acc+q)&0xff; }\n"
"  partials[blk]=acc;\n"
"}\n"
"extern \"C\" __global__ void exrg_pred_offsets(int* partials, int nblk, int* offs){\n"
"  int acc=0; for(int b=0;b<nblk;b++){ offs[b]=acc; acc=(acc+partials[b])&0xff; }\n"
"}\n"
"extern \"C\" __global__ void exrg_pred_apply(const u8* p, int n, int tile, const int* offs, u8* out){\n"
"  int blk=blockIdx.x; long s=(long)blk*tile; long e=s+tile; if(e>n) e=n;\n"
"  int acc=offs[blk]; for(long i=s;i<e;i++){ int q=(i==0)?(int)p[0]:((int)p[i]-128); acc=(acc+q)&0xff; out[i]=(u8)acc; }\n"
"}\n"
"\n"
/* predictor encode: out[i]= i?(in[i]-in[i-1]+384)&0xff : in[0] (parallel). */
"extern \"C\" __global__ void exrg_pred_encode(const u8* in, int n, u8* out){\n"
"  long i=(long)blockIdx.x*blockDim.x+threadIdx.x; if(i>=n) return;\n"
"  out[i]=(i==0)?in[0]:(u8)(((int)in[i]-(int)in[i-1]+384)&0xff);\n"
"}\n"
"\n"
/* byte deinterleave (decode): src first half -> even, second half -> odd. */
"extern \"C\" __global__ void exrg_deinterleave(const u8* src, int n, u8* dst){\n"
"  long i=(long)blockIdx.x*blockDim.x+threadIdx.x; if(i>=n) return;\n"
"  long half=(n+1)/2; dst[i]=(i&1)? src[half+(i>>1)] : src[i>>1];\n"
"}\n"
/* byte interleave (encode): even bytes -> first half, odd -> second half. */
"extern \"C\" __global__ void exrg_interleave(const u8* src, int n, u8* dst){\n"
"  long i=(long)blockIdx.x*blockDim.x+threadIdx.x; if(i>=n) return;\n"
"  long half=(n+1)/2; if(i<half) dst[i]=src[i*2]; else { long j=i-half; dst[i]=src[j*2+1]; }\n"
"}\n"
"\n"
/* strided byte copy: rows of rowLen, src stride sStride, dst stride dStride. */
"extern \"C\" __global__ void exrg_strided_copy(u8* dst,int dStride,const u8* src,int sStride,int rowLen,int rows){\n"
"  long t=(long)blockIdx.x*blockDim.x+threadIdx.x; long total=(long)rowLen*rows; if(t>=total) return;\n"
"  int row=(int)(t/rowLen); int k=(int)(t%rowLen); dst[(long)row*dStride+k]=src[(long)row*sStride+k];\n"
"}\n"
"\n"
/* gather one planar typed channel into interleaved float32 (widen). */
"extern \"C\" __global__ void exrg_gather_f32(float* out,int outCh,int cdst,const void* src,int stype,long n){\n"
"  long p=(long)blockIdx.x*blockDim.x+threadIdx.x; if(p>=n) return; float v;\n"
"  if(stype==2) v=((const float*)src)[p];\n"
"  else if(stype==1) v=exrg_half_to_float(((const u16*)src)[p]);\n"
"  else v=(float)((const u32*)src)[p];\n"
"  out[p*outCh+cdst]=v;\n"
"}\n"
/* scatter one channel of interleaved float32 into planar typed buffer (narrow).*/
"extern \"C\" __global__ void exrg_scatter_f32(void* dst,int dtype,const float* in,int inCh,int csrc,long n){\n"
"  long p=(long)blockIdx.x*blockDim.x+threadIdx.x; if(p>=n) return; float v=in[p*inCh+csrc];\n"
"  if(dtype==2) ((float*)dst)[p]=v;\n"
"  else if(dtype==1) ((u16*)dst)[p]=exrg_float_to_half(v);\n"
"  else { double d=(double)v; if(d<0) d=0; if(d>4294967295.0) d=4294967295.0; ((u32*)dst)[p]=(u32)(d+0.5); }\n"
"}\n"
"\n"
/* generic element-wise pixel-type convert (UINT/HALF/FLOAT, RAW vs NORM). */
"extern \"C\" __global__ void exrg_convert(void* dst,int dtype,const void* src,int stype,long n,int norm){\n"
"  long i=(long)blockIdx.x*blockDim.x+threadIdx.x; if(i>=n) return; float v;\n"
"  if(stype==2) v=((const float*)src)[i];\n"
"  else if(stype==1) v=exrg_half_to_float(((const u16*)src)[i]);\n"
"  else { u32 u=((const u32*)src)[i]; v=norm?((float)u/4294967295.0f):(float)u; }\n"
"  if(dtype==2) ((float*)dst)[i]=v;\n"
"  else if(dtype==1) ((u16*)dst)[i]=exrg_float_to_half(v);\n"
"  else { double d=norm?((double)v*4294967295.0):(double)v; if(d<0)d=0; if(d>4294967295.0)d=4294967295.0; ((u32*)dst)[i]=(u32)(d+0.5); }\n"
"}\n"
"\n"
/* ===== processing ====================================================== */
"extern \"C\" __global__ void exrg_color_matrix(float* dst,const float* src,long n,int ch,float m0,float m1,float m2,float m3,float m4,float m5,float m6,float m7,float m8){\n"
"  long p=(long)blockIdx.x*blockDim.x+threadIdx.x; if(p>=n) return; const float* s=src+p*ch; float* d=dst+p*ch;\n"
"  float r=s[0], g=(ch>1)?s[1]:0.f, b=(ch>2)?s[2]:0.f;\n"
"  d[0]=m0*r+m1*g+m2*b; if(ch>1) d[1]=m3*r+m4*g+m5*b; if(ch>2) d[2]=m6*r+m7*g+m8*b;\n"
"  for(int c=3;c<ch;c++) d[c]=s[c];\n"
"}\n"
"\n"
"__device__ __forceinline__ float exrg_srgb_oetf(float x){ return (x<=0.0031308f)?(12.92f*x):(1.055f*powf(x,1.0f/2.4f)-0.055f); }\n"
"__device__ __forceinline__ float exrg_srgb_eotf(float x){ return (x<=0.04045f)?(x/12.92f):powf((x+0.055f)/1.055f,2.4f); }\n"
"extern \"C\" __global__ void exrg_transfer(float* dst,const float* src,long n,int tf,int decode){\n"
"  long i=(long)blockIdx.x*blockDim.x+threadIdx.x; if(i>=n) return; float x=src[i], y=x;\n"
"  if(tf==0){ y=x; }\n"
"  else if(tf==1){ y=decode?exrg_srgb_eotf(x):exrg_srgb_oetf(x); }\n"
"  else if(tf==2){ y=decode?powf(x,2.2f):powf(x,1.0f/2.2f); }\n"
"  else if(tf==3){ y=decode?powf(x,2.4f):powf(x,1.0f/2.4f); }\n"
"  else if(tf==4){ y=decode?((x<0.081f)?(x/4.5f):powf((x+0.099f)/1.099f,1.0f/0.45f)):((x<0.018f)?(4.5f*x):(1.099f*powf(x,0.45f)-0.099f)); }\n"
"  dst[i]=y;\n"
"}\n"
"\n"
"__device__ __forceinline__ float exrg_aces(float x){ float a=2.51f,b=0.03f,c=2.43f,d=0.59f,e=0.14f; return (x*(a*x+b))/(x*(c*x+d)+e); }\n"
"extern \"C\" __global__ void exrg_tonemap(float* dst,const float* src,long n,int ch,int op,float exposure,float white){\n"
"  long p=(long)blockIdx.x*blockDim.x+threadIdx.x; if(p>=n) return; const float* s=src+p*ch; float* d=dst+p*ch;\n"
"  int rgb=(ch<3)?ch:3;\n"
"  for(int c=0;c<rgb;c++){ float x=s[c]*exposure; float y;\n"
"    if(op==0) y=x/(1.0f+x);\n"
"    else if(op==1){ float w=(white<=0.f)?1.f:white; y=x*(1.0f+x/(w*w))/(1.0f+x); }\n"
"    else y=exrg_aces(x);\n"
"    if(y<0.f)y=0.f; d[c]=y; }\n"
"  for(int c=rgb;c<ch;c++) d[c]=s[c];\n"
"}\n"
"\n"
"extern \"C\" __global__ void exrg_lut3d(float* dst,const float* src,long n,int ch,const float* lut,int sz,float dmin0,float dmin1,float dmin2,float dmax0,float dmax1,float dmax2){\n"
"  long p=(long)blockIdx.x*blockDim.x+threadIdx.x; if(p>=n) return; const float* s=src+p*ch; float* d=dst+p*ch;\n"
"  float dmn[3]={dmin0,dmin1,dmin2}, dmx[3]={dmax0,dmax1,dmax2}; float fc[3]; int i0[3]; float fr[3];\n"
"  for(int c=0;c<3;c++){ float in=(ch>c)?s[c]:0.f; float t=(in-dmn[c])/(dmx[c]-dmn[c]); if(t<0.f)t=0.f; if(t>1.f)t=1.f; fc[c]=t*(sz-1); int ii=(int)fc[c]; if(ii>sz-2)ii=sz-2; if(ii<0)ii=0; i0[c]=ii; fr[c]=fc[c]-ii; }\n"
"  float out[3]={0,0,0};\n"
"  for(int corner=0;corner<8;corner++){ int dx=corner&1,dy=(corner>>1)&1,dz=(corner>>2)&1;\n"
"    float w=((dx?fr[0]:1-fr[0])*(dy?fr[1]:1-fr[1])*(dz?fr[2]:1-fr[2]));\n"
"    int ir=i0[0]+dx, ig=i0[1]+dy, ib=i0[2]+dz; long idx=(((long)ib*sz+ig)*sz+ir)*3;\n"
"    out[0]+=w*lut[idx]; out[1]+=w*lut[idx+1]; out[2]+=w*lut[idx+2]; }\n"
"  for(int c=0;c<3 && c<ch;c++) d[c]=out[c]; for(int c=3;c<ch;c++) d[c]=s[c];\n"
"}\n"
"\n"
/* ===== resize: separable, precomputed weight/index tables ============== */
/* For each dst x: contrib[k] in [0,support) with weight w and source index. */
"extern \"C\" __global__ void exrg_resize_h(const float* src,int sw,int sh,int sstride,float* dst,int dw,int dstride,int ch,const float* wts,const int* idx,int support){\n"
"  long t=(long)blockIdx.x*blockDim.x+threadIdx.x; long total=(long)dw*sh; if(t>=total) return;\n"
"  int ox=(int)(t%dw); int y=(int)(t/dw); const float* wrow=wts+(long)ox*support; const int* irow=idx+(long)ox*support;\n"
"  for(int c=0;c<ch;c++){ float acc=0.f; for(int k=0;k<support;k++){ int sx=irow[k]; acc+=wrow[k]*src[(long)y*sstride+sx*ch+c]; } dst[(long)y*dstride+ox*ch+c]=acc; }\n"
"}\n"
"extern \"C\" __global__ void exrg_resize_v(const float* src,int sw,int sh,int sstride,float* dst,int dw,int dh,int dstride,int ch,const float* wts,const int* idx,int support){\n"
"  long t=(long)blockIdx.x*blockDim.x+threadIdx.x; long total=(long)dw*dh; if(t>=total) return;\n"
"  int x=(int)(t%dw); int oy=(int)(t/dw); const float* wrow=wts+(long)oy*support; const int* irow=idx+(long)oy*support;\n"
"  for(int c=0;c<ch;c++){ float acc=0.f; for(int k=0;k<support;k++){ int sy=irow[k]; acc+=wrow[k]*src[(long)sy*sstride+x*ch+c]; } dst[(long)oy*dstride+x*ch+c]=acc; }\n"
"}\n"
/* premultiply / unpremultiply rgb by alpha channel ac (interleaved). */
"extern \"C\" __global__ void exrg_premult(float* buf,long n,int ch,int ac,int undo){\n"
"  long p=(long)blockIdx.x*blockDim.x+threadIdx.x; if(p>=n) return; float* d=buf+p*ch; float a=d[ac];\n"
"  if(!undo){ for(int c=0;c<ch;c++) if(c!=ac) d[c]*=a; }\n"
"  else { if(a!=0.f){ float ia=1.0f/a; for(int c=0;c<ch;c++) if(c!=ac) d[c]*=ia; } }\n"
"}\n"
;
