/*
 * TinyEXR - CUDA HTJ2K HT block-coder kernel, embedded as an NVRTC source
 * string. Included only inside the EXR_USE_CUDA block of exr_gpu_cuda.c.
 *
 * One thread decodes one HT code-block (<=128x32). This is a direct
 * transcription of the SCALAR reference path of jph_decode_block_core() in
 * src/exr_jph.c (the AVX2 / use_frwd / four-quad branches are CPU-SIMD
 * optimisations producing identical output, so they are omitted here). The
 * decoded sign/magnitude coefficients are written as int32 to a per-block tile.
 * Bit-exact with the CPU coder by construction.
 *
 * Per-thread scratch lives in caller-provided global slabs (the working set is
 * ~30 KB/block, too large for registers): each thread t indexes its slab at
 * t*stride. Slab strides are the worst-case sizes for a 128x32 block.
 *
 * Copyright (c) 2014-2026 Syoyo Fujita and TinyEXR authors
 * SPDX-License-Identifier: BSD-3-Clause
 */

static const char *EXR_GPU_JPH_KERNEL_SRC =
"typedef unsigned char u8;\n"
"typedef unsigned short u16;\n"
"typedef unsigned int u32;\n"
"typedef unsigned long long u64;\n"
"typedef long long i64;\n"
"\n"
"struct JphGpuRec {\n"
"  u32 width, height, missing_msbs, active_passes;\n"
"  u32 length0, length1, kmax;\n"
"  u64 data_offset;\n"
"  u64 out_offset;\n"   /* int32 element offset into out_coeffs */
"  u32 out_stride;\n"
"  u32 eligible;\n"
"};\n"
"\n"
"__device__ __forceinline__ u32 d_mask32(u32 n){ return n>=32u?0xffffffffu:((1u<<n)-1u); }\n"
"__device__ __forceinline__ u64 d_mask64(u32 n){ return n>=64u?~0ull:((1ull<<n)-1ull); }\n"
"__device__ __forceinline__ u32 d_loadu32(const u16*p){ return (u32)p[0]|((u32)p[1]<<16); }\n"
"__device__ __forceinline__ u32 d_popc(u32 v){ return (u32)__popc(v); }\n"
"\n"
/* ===== MEL reader ====================================================== */
"struct DMel { const u8*p; const u8*end; u64 bits; u32 bit_count; int prev_ff; int k; };\n"
"__device__ void d_mel_init(DMel*r,const u8*data,u64 size){ r->p=data; r->end=data?data+size:data; r->bits=0; r->bit_count=0; r->prev_ff=0; r->k=0; }\n"
"__device__ int d_mel_read_bits(DMel*r,unsigned nbits,u32*out){\n"
"  u64 mask;\n"
"  if(nbits>32u) return 0;\n"
"  while(r->bit_count<nbits){\n"
"    u8 byte; unsigned add_bits=8;\n"
"    if(r->p && r->p<r->end){ byte=*r->p++; if(r->p==r->end) byte|=0x0fu; } else byte=0xffu;\n"
"    if(r->prev_ff){ if(byte>0x8fu) return 0; byte&=0x7fu; add_bits=7; }\n"
"    if(r->bit_count+add_bits>64u) return 0;\n"
"    r->bits=(r->bits<<add_bits)|(u64)byte; r->bit_count+=add_bits;\n"
"    r->prev_ff=(add_bits==8u && byte==0xffu);\n"
"  }\n"
"  if(nbits==0){ *out=0; return 1; }\n"
"  mask=(nbits==32u)?0xffffffffull:((1ull<<nbits)-1u);\n"
"  *out=(u32)((r->bits>>(r->bit_count-nbits))&mask);\n"
"  r->bit_count-=nbits;\n"
"  if(r->bit_count==0) r->bits=0; else r->bits&=((1ull<<r->bit_count)-1u);\n"
"  return 1;\n"
"}\n"
"__device__ int d_mel_get_run(DMel*r,u32*zero_run,int*has_one){\n"
"  const u8 mel_exp[13]={0,0,0,1,1,1,2,2,2,3,3,4,5};\n"
"  u32 bit=0,v=0; u8 eval;\n"
"  if(r->k<0||r->k>12) return 0;\n"
"  eval=mel_exp[r->k];\n"
"  if(!d_mel_read_bits(r,1,&bit)) return 0;\n"
"  if(bit){ *zero_run=(1u<<eval)-1u; *has_one=0; if(r->k<12) r->k++; return 1; }\n"
"  if(eval){ if(!d_mel_read_bits(r,eval,&v)) return 0; }\n"
"  *zero_run=v; *has_one=1; if(r->k>0) r->k--; return 1;\n"
"}\n"
"\n"
/* ===== VLC reverse reader ============================================== */
"struct DVlc { const u8*data; const u8*start; u64 tmp; u32 bits; u32 unstuff; u32 size; };\n"
"__device__ int d_vlc_read(DVlc*v){\n"
"  u32 val=0,out_bits=0,tmp=0,u=v->unstuff;\n"
"  if(v->bits>32u) return 1;\n"
"  if(v->size>3u){ const u8*p=v->data-3; val=((u32)p[0])|((u32)p[1]<<8)|((u32)p[2]<<16)|((u32)p[3]<<24); v->data-=4; v->size-=4; }\n"
"  else if(v->size>0u){ u32 i=24; while(v->size>0u){ u32 b=*v->data--; val|=(b<<i); v->size--; i-=8; } }\n"
"  { u8 b=(u8)(val>>24); u32 nb=(u&&((b&0x7Fu)==0x7Fu))?7u:8u; u=(b>0x8Fu)?1u:0u; tmp=b; out_bits+=nb; }\n"
"  { u8 b=(u8)(val>>16); u32 nb=(u&&((b&0x7Fu)==0x7Fu))?7u:8u; u=(b>0x8Fu)?1u:0u; tmp|=(u32)b<<out_bits; out_bits+=nb; }\n"
"  { u8 b=(u8)(val>>8);  u32 nb=(u&&((b&0x7Fu)==0x7Fu))?7u:8u; u=(b>0x8Fu)?1u:0u; tmp|=(u32)b<<out_bits; out_bits+=nb; }\n"
"  { u8 b=(u8)val;       u32 nb=(u&&((b&0x7Fu)==0x7Fu))?7u:8u; v->unstuff=(b>0x8Fu)?1u:0u; tmp|=(u32)b<<out_bits; out_bits+=nb; }\n"
"  v->tmp|=(u64)tmp<<v->bits; v->bits+=out_bits; return 1;\n"
"}\n"
"__device__ int d_vlc_init(DVlc*v,const u8*buf,u32 lcup,u32 scup){\n"
"  u32 i,num,tnum;\n"
"  if(scup<2u||lcup<scup) return 0;\n"
"  v->data=0;v->start=0;v->tmp=0;v->bits=0;v->unstuff=0;v->size=0;\n"
"  v->data=buf+lcup-2u; v->start=buf; v->size=scup-2u;\n"
"  { u8 d=*v->data--; v->tmp=(u64)(d>>4); v->bits=4u-(((v->tmp&7u)==7u)?1u:0u); v->unstuff=((d|0x0Fu)>0x8Fu)?1u:0u; }\n"
"  num=1u+((u32)(unsigned long long)(v->data)&3u);\n"
"  tnum=num<v->size?num:v->size;\n"
"  for(i=0;i<tnum;++i){ u8 d=*v->data--; u32 nb=8u-((v->unstuff&&((d&0x7Fu)==0x7Fu))?1u:0u); v->tmp|=(u64)d<<v->bits; v->bits+=nb; v->unstuff=(d>0x8Fu)?1u:0u; }\n"
"  v->size-=tnum;\n"
"  if(v->bits<=32u){ if(!d_vlc_read(v)) return 0; }\n"
"  return 1;\n"
"}\n"
"__device__ u32 d_vlc_fetch(DVlc*v){ while(v->bits<32u){ d_vlc_read(v); } return (u32)v->tmp; }\n"
"__device__ u32 d_vlc_advance(DVlc*v,u32 n){ if(n>v->bits) n=v->bits; v->tmp>>=n; v->bits-=n; return (u32)v->tmp; }\n"
"__device__ int d_mrp_init(DVlc*v,const u8*buf,u32 lcup,u32 len2){\n"
"  u32 i,num;\n"
"  v->data=0;v->start=0;v->tmp=0;v->bits=0;v->unstuff=0;v->size=0;\n"
"  v->data=buf+lcup+len2-1u; v->start=buf+lcup; v->size=len2; v->unstuff=1u;\n"
"  num=1u+((u32)(unsigned long long)(v->data)&3u);\n"
"  for(i=0;i<num;++i){ u64 d=0; u32 nb; if(v->size>0u){ d=*v->data--; v->size--; } nb=8u-((v->unstuff&&(((u32)d&0x7fu)==0x7fu))?1u:0u); v->tmp|=d<<v->bits; v->bits+=nb; v->unstuff=(d>0x8fu)?1u:0u; }\n"
"  return d_vlc_read(v);\n"
"}\n"
"__device__ u32 d_mrp_fetch(DVlc*v){ if(v->bits<32u){ d_vlc_read(v); if(v->bits<32u) d_vlc_read(v); } return (u32)v->tmp; }\n"
"\n"
/* ===== MagSgn forward reader (unstuffed bit buffer) ==================== */
"struct DMagSgn { u64*buf; u64 real_bits; u64 cursor; u64 fill_word; };\n"
"__device__ u64 d_unstuff_bits(const u8*data,u32 size,u64*out){\n"
"  u64 nbits=0u; u32 idx,prevff=0u;\n"
"  u64 acc=0u; u32 accbits=0u; unsigned long long w=0u; unsigned long long out_words=(unsigned long long)size/8u+3u;\n"
"  for(idx=0u;idx<size;++idx){\n"
"    u8 b=data?data[idx]:0u; u32 ub=prevff?7u:8u; u64 uv=(u64)(b&(u8)((1u<<ub)-1u)); u32 old=accbits;\n"
"    acc|=uv<<old; accbits+=ub; nbits+=ub;\n"
"    if(accbits>=64u){ out[w++]=acc; accbits-=64u; acc=accbits?(uv>>(64u-old)):0u; }\n"
"    prevff=(b==0xffu)?1u:0u;\n"
"  }\n"
"  if(accbits) out[w++]=acc;\n"
"  while(w<out_words) out[w++]=0u;\n"
"  return nbits;\n"
"}\n"
"__device__ void d_fwdbits_init(DMagSgn*m,const u8*data,u32 size,u8 fill,u64*bitbuf){\n"
"  m->buf=bitbuf; m->cursor=0u; m->fill_word=fill?~0ull:0ull; m->real_bits=d_unstuff_bits(data,size,bitbuf);\n"
"}\n"
"__device__ u64 d_magsgn_fetch64_at(const DMagSgn*m,u64 c){\n"
"  u64 v,avail; u32 off;\n"
"  if(c>=m->real_bits) return m->fill_word;\n"
"  off=(u32)(c&63u); v=m->buf[c>>6u]>>off;\n"
"  if(off) v|=m->buf[(c>>6u)+1u]<<(64u-off);\n"
"  avail=m->real_bits-c;\n"
"  if(avail<64u && m->fill_word) v|=~0ull<<avail;\n"
"  return v;\n"
"}\n"
"__device__ u32 d_magsgn_fetch(DMagSgn*m){ return (u32)d_magsgn_fetch64_at(m,m->cursor); }\n"
"__device__ void d_magsgn_advance(DMagSgn*m,u32 n){ m->cursor+=n; }\n"
"\n"
/* per-quad MagSgn sampler (JphQuadMs) */
"struct DQuad { u64 lo,hi,base; u32 off; int hi_loaded; };\n"
"__device__ void d_quad_begin(DQuad*q,const DMagSgn*m){ q->base=m->cursor; q->lo=d_magsgn_fetch64_at(m,q->base); q->hi=0u; q->off=0u; q->hi_loaded=0; }\n"
"__device__ u32 d_quad_sample(DQuad*q,const DMagSgn*m,u32 inf,u32 bit,u32 U_q,u32 p,u32*v_n_out){\n"
"  u32 val=0u,v_n=0u;\n"
"  if(inf&(1u<<(4u+bit))){\n"
"    u32 o=q->off; u32 m_n=U_q-((inf>>(12u+bit))&1u); u32 ms;\n"
"    if(o+m_n>127u){ *v_n_out=0u; return 0u; }\n"
"    if(o+m_n>64u && !q->hi_loaded){ q->hi=d_magsgn_fetch64_at(m,q->base+64u); q->hi_loaded=1; }\n"
"    ms=(o<64u)?(u32)((q->lo>>o)|(o?(q->hi<<(64u-o)):0u)):(u32)(q->hi>>(o-64u));\n"
"    val=ms<<31; v_n=ms&d_mask32(m_n); v_n|=((inf>>(8u+bit))&1u)<<m_n; v_n|=1u; val|=(v_n+2u)<<(p-1u); q->off=o+m_n;\n"
"  }\n"
"  *v_n_out=v_n; return val;\n"
"}\n"
"__device__ void d_quad_end(DQuad*q,DMagSgn*m){ m->cursor=q->base+q->off; }\n"
"\n"
/* ===== the per-code-block decode (scalar reference transcription) ====== */
"extern \"C\" __global__ void exrg_jph_decode_blocks(\n"
"    const u8* data, const JphGpuRec* recs, int num_recs,\n"
"    const u16* vlc0, const u16* vlc1, const u16* uvlc0, const u16* uvlc1,\n"
"    int* out_coeffs,\n"
"    u16* scratch_all, u32 scratch_stride,\n"
"    u32* buf_all, u32 buf_stride,\n"
"    u32* vn_all, u32 vn_stride,\n"
"    u64* magsgn_all, u32 magsgn_stride,\n"
"    u64* sigprop_all, u32 sigprop_stride){\n"
"  int tid=blockIdx.x*blockDim.x+threadIdx.x;\n"
"  if(tid>=num_recs) return;\n"
"  JphGpuRec rec=recs[tid];\n"
"  if(!rec.eligible) return;\n"
"  const u8* sd=data+rec.data_offset;\n"
"  u32 width=rec.width, height=rec.height, missing_msbs=rec.missing_msbs;\n"
"  u32 num_passes=rec.active_passes, lengths1=rec.length0, lengths2=rec.length1;\n"
"  u32 kmax=rec.kmax, p, mmsbp2, lcup, scup, sstr;\n"
"  u16* scratch=scratch_all+(u64)tid*scratch_stride;\n"
"  u32* buf=buf_all+(u64)tid*buf_stride;\n"
"  u32* v_n_scratch=vn_all+(u64)tid*vn_stride;\n"
"  u64* magsgn_bits=magsgn_all+(u64)tid*magsgn_stride;\n"
"  u64* sigprop_bits=sigprop_all+(u64)tid*sigprop_stride;\n"
"  DMel mel; DVlc vlc; DMagSgn magsgn; u32 run,vlc_val,c_q; int ii;\n"
"  u16* sp; u32* dp; i64 prev_v_n; (void)ii;\n"
"  if(num_passes>1u && lengths2==0u) num_passes=1u;\n"
"  if(num_passes<1u||num_passes>3u) return;\n"
"  if(missing_msbs>=30u||kmax>30u) return;\n"
"  if(missing_msbs==29u && num_passes>1u) num_passes=1u;\n"
"  if(lengths1<2u) return;\n"
"  lcup=lengths1; scup=((u32)sd[lcup-1u]<<4)|(sd[lcup-2u]&0x0Fu);\n"
"  if(scup<2u||scup>lcup||scup>4079u) return;\n"
"  p=30u-missing_msbs; mmsbp2=missing_msbs+2u;\n"
"  sstr=((width+2u)+7u)&~7u;\n"
"  d_mel_init(&mel, sd+lcup-scup, (u64)scup-1u);\n"
"  if(!d_vlc_init(&vlc, sd, lcup, scup)) return;\n"
"  d_fwdbits_init(&magsgn, sd, lcup-scup, 0xffu, magsgn_bits);\n"
"  if(!d_mel_get_run(&mel,&run,&ii)) ii=0;\n"
"  if(ii) run=(run<<1)|1u; else run=run<<1;\n"
/* --- cleanup: initial quad row VLC parse --- */
"  c_q=0u; sp=scratch;\n"
"  { u32 x=0u; while(x<width){\n"
"    u16 t0,t1; u32 uvlc_mode,uvlc_entry,len,tmp,q0_suffix_len,q0,q1;\n"
"    vlc_val=d_vlc_fetch(&vlc); t0=vlc0[c_q+(vlc_val&0x7Fu)];\n"
"    if(c_q==0u){ run-=2u; t0=(run==0xffffffffu)?t0:0u; if((int)run<0){ if(!d_mel_get_run(&mel,&run,&ii)) ii=0; if(ii) run=(run<<1)|1u; else run=run<<1; } }\n"
"    sp[0]=t0; x+=2u; c_q=((t0&0x10u)<<3u)|((t0&0xE0u)<<2u); vlc_val=d_vlc_advance(&vlc,t0&0x7u);\n"
"    t1=0u; vlc_val=d_vlc_fetch(&vlc); t1=vlc0[c_q+(vlc_val&0x7Fu)];\n"
"    if(c_q==0u && x<width){ run-=2u; t1=(run==0xffffffffu)?t1:0u; if((int)run<0){ if(!d_mel_get_run(&mel,&run,&ii)) ii=0; if(ii) run=(run<<1)|1u; else run=run<<1; } }\n"
"    t1=(x<width)?t1:0u; sp[2]=t1; x+=2u; c_q=((t1&0x10u)<<3u)|((t1&0xE0u)<<2u); vlc_val=d_vlc_advance(&vlc,t1&0x7u);\n"
"    uvlc_mode=((t0&0x8u)<<3u)|((t1&0x8u)<<4u);\n"
"    if(uvlc_mode==0xC0u){ run-=2u; uvlc_mode+=(run==0xffffffffu)?0x40u:0u; if((int)run<0){ if(!d_mel_get_run(&mel,&run,&ii)) ii=0; if(ii) run=(run<<1)|1u; else run=run<<1; } }\n"
"    uvlc_entry=uvlc0[uvlc_mode+(vlc_val&0x3Fu)]; vlc_val=d_vlc_advance(&vlc,uvlc_entry&0x7u); uvlc_entry>>=3u;\n"
"    len=uvlc_entry&0xFu; tmp=vlc_val&((1u<<len)-1u); vlc_val=d_vlc_advance(&vlc,len); uvlc_entry>>=4u;\n"
"    q0_suffix_len=uvlc_entry&0x7u; uvlc_entry>>=3u;\n"
"    q0=(uvlc_entry&0x7u)+(tmp&((1u<<q0_suffix_len)-1u)); sp[1]=(u16)(1u+q0);\n"
"    q1=(uvlc_entry>>3u)+(tmp>>q0_suffix_len); sp[3]=(u16)(1u+q1); sp+=4u;\n"
"  } }\n"
"  for(int z=0;z<8;++z) sp[z]=0;\n"
/* --- cleanup: non-initial quad rows --- */
"  { u32 y; for(y=2u;y<height;y+=2u){ u32 x=0u; sp=scratch+(y>>1u)*sstr; c_q=0u;\n"
"    while(x<width){\n"
"      u16 t0,t1; u32 uvlc_entry,len,tmp,q0,q1,q0_suffix_len;\n"
"      c_q|=((sp[0-(int)sstr]&0xA0u)<<2u); c_q|=((sp[2-(int)sstr]&0x20u)<<4u);\n"
"      vlc_val=d_vlc_fetch(&vlc); t0=vlc1[c_q+(vlc_val&0x7Fu)];\n"
"      if(c_q==0u){ run-=2u; t0=(run==0xffffffffu)?t0:0u; if((int)run<0){ if(!d_mel_get_run(&mel,&run,&ii)) ii=0; if(ii) run=(run<<1)|1u; else run=run<<1; } }\n"
"      sp[0]=t0; x+=2u;\n"
"      c_q=((t0&0x40u)<<2u)|((t0&0x80u)<<1u); c_q|=sp[0-(int)sstr]&0x80u; c_q|=((sp[2-(int)sstr]&0xA0u)<<2u); c_q|=((sp[4-(int)sstr]&0x20u)<<4u);\n"
"      vlc_val=d_vlc_advance(&vlc,t0&0x7u);\n"
"      t1=0u; vlc_val=d_vlc_fetch(&vlc); t1=vlc1[c_q+(vlc_val&0x7Fu)];\n"
"      if(c_q==0u && x<width){ run-=2u; t1=(run==0xffffffffu)?t1:0u; if((int)run<0){ if(!d_mel_get_run(&mel,&run,&ii)) ii=0; if(ii) run=(run<<1)|1u; else run=run<<1; } }\n"
"      t1=(x<width)?t1:0u; sp[2]=t1; x+=2u;\n"
"      c_q=((t1&0x40u)<<2u)|((t1&0x80u)<<1u); c_q|=sp[2-(int)sstr]&0x80u; vlc_val=d_vlc_advance(&vlc,t1&0x7u);\n"
"      { u32 uvlc_mode=((t0&0x8u)<<3u)|((t1&0x8u)<<4u);\n"
"        uvlc_entry=uvlc1[uvlc_mode+(vlc_val&0x3Fu)]; vlc_val=d_vlc_advance(&vlc,uvlc_entry&0x7u); uvlc_entry>>=3u;\n"
"        len=uvlc_entry&0xFu; tmp=vlc_val&((1u<<len)-1u); vlc_val=d_vlc_advance(&vlc,len); uvlc_entry>>=4u;\n"
"        q0_suffix_len=uvlc_entry&0x7u; uvlc_entry>>=3u;\n"
"        q0=(uvlc_entry&0x7u)+(tmp&((1u<<q0_suffix_len)-1u)); sp[1]=(u16)q0;\n"
"        q1=(uvlc_entry>>3u)+(tmp>>q0_suffix_len); sp[3]=(u16)q1; }\n"
"      sp+=4u;\n"
"    }\n"
"    for(int z=0;z<8;++z) sp[z]=0;\n"
"  } }\n"
/* --- MagSgn: initial row --- */
"  { u32 x=0u; u32* vp=v_n_scratch; prev_v_n=0; sp=scratch; dp=buf;\n"
"    while(x<width){\n"
"      u32 inf=sp[0]; u32 U_q=sp[1]; u32 v_n=0u,ignore; DQuad q;\n"
"      if(U_q>mmsbp2) return;\n"
"      d_quad_begin(&q,&magsgn);\n"
"      dp[0]=d_quad_sample(&q,&magsgn,inf,0u,U_q,p,&ignore);\n"
"      { u32 val=d_quad_sample(&q,&magsgn,inf,1u,U_q,p,&v_n); if(1u<height) dp[sstr]=val; }\n"
"      vp[0]=(u32)(prev_v_n|v_n); prev_v_n=0; ++dp; ++x;\n"
"      if(x>=width){ d_quad_end(&q,&magsgn); ++vp; break; }\n"
"      dp[0]=d_quad_sample(&q,&magsgn,inf,2u,U_q,p,&ignore);\n"
"      { u32 val=d_quad_sample(&q,&magsgn,inf,3u,U_q,p,&v_n); if(1u<height) dp[sstr]=val; }\n"
"      d_quad_end(&q,&magsgn); prev_v_n=v_n; ++dp; ++x; sp+=2u; ++vp;\n"
"    }\n"
"    vp[0]=(u32)prev_v_n;\n"
"  }\n"
/* --- MagSgn: non-initial rows --- */
"  { u32 y; for(y=2u;y<height;y+=2u){ u32 x=0u; u32* vp=v_n_scratch; prev_v_n=0; sp=scratch+(y>>1u)*sstr; dp=buf+y*sstr;\n"
"    while(x<width){\n"
"      u32 inf=sp[0]; u32 u_q=sp[1]; u32 gamma=inf&0xF0u; gamma&=gamma-0x10u;\n"
"      u32 emax=vp[0]|vp[1]; int lz=0; u32 v,U_q,kappa; v=emax|2u;\n"
"      if((v&0xFFFF0000u)==0u){ lz+=16; v<<=16; }\n"
"      if((v&0xFF000000u)==0u){ lz+=8; v<<=8; }\n"
"      if((v&0xF0000000u)==0u){ lz+=4; v<<=4; }\n"
"      if((v&0xC0000000u)==0u){ lz+=2; v<<=2; }\n"
"      if((v&0x80000000u)==0u) lz+=1;\n"
"      emax=31u-(u32)lz; kappa=gamma?emax:1u; U_q=u_q+kappa;\n"
"      if(U_q>mmsbp2) return;\n"
"      { u32 v_n=0u,ignore; DQuad q; d_quad_begin(&q,&magsgn);\n"
"        dp[0]=d_quad_sample(&q,&magsgn,inf,0u,U_q,p,&ignore);\n"
"        { u32 val=d_quad_sample(&q,&magsgn,inf,1u,U_q,p,&v_n); if(y+1u<height) dp[sstr]=val; }\n"
"        vp[0]=(u32)(prev_v_n|v_n); prev_v_n=0; ++dp; ++x;\n"
"        if(x>=width){ d_quad_end(&q,&magsgn); ++vp; break; }\n"
"        dp[0]=d_quad_sample(&q,&magsgn,inf,2u,U_q,p,&ignore);\n"
"        { u32 val=d_quad_sample(&q,&magsgn,inf,3u,U_q,p,&v_n); if(y+1u<height) dp[sstr]=val; }\n"
"        d_quad_end(&q,&magsgn); prev_v_n=v_n; ++dp; ++x; }\n"
"      sp+=2u; ++vp;\n"
"    }\n"
"    vp[0]=(u32)prev_v_n;\n"
"  } }\n"
/* --- SigProp + MagRef passes (num_passes>1) --- */
"  if(num_passes>1u){\n"
"    u16* sigma=scratch; u32 mstr=(width+3u)>>2u; u16 prev_row_sig[264]; DMagSgn sigprop;\n"
"    mstr=((mstr+2u)+7u)&~7u;\n"
"    { u32 y; for(y=0u;y<height;y+=4u){ u16* ssp=scratch+(y>>1u)*sstr; u16* sdp=sigma+(y>>2u)*mstr; u32 x;\n"
"        for(x=0u;x<width;x+=4u,ssp+=4u,++sdp){ u32 t0=0u,t1=0u;\n"
"          t0=((ssp[0]&0x30u)>>4u)|((ssp[0]&0xc0u)>>2u); t0|=((ssp[2]&0x30u)<<4u)|((ssp[2]&0xc0u)<<6u);\n"
"          t1=((ssp[sstr]&0x30u)>>2u)|(ssp[sstr]&0xc0u); t1|=((ssp[2u+sstr]&0x30u)<<6u)|((ssp[2u+sstr]&0xc0u)<<8u);\n"
"          sdp[0]=(u16)(t0|t1); }\n"
"        sdp[0]=0u; }\n"
"      { u32 y2=((height+3u)/4u)*4u; u16* sdp=sigma+(y2>>2u)*mstr; u32 x; for(x=0u;x<width;x+=4u,++sdp) sdp[0]=0u; sdp[0]=0u; }\n"
"    }\n"
"    for(int z=0;z<264;++z) prev_row_sig[z]=0;\n"
"    d_fwdbits_init(&sigprop, sd+lengths1, lengths2, 0u, sigprop_bits);\n"
"    { u32 y; for(y=0u;y<height;y+=4u){ u32 row_pattern=0xffffu; u32 prev=0u; u16* prev_sig=prev_row_sig; u16* cur_sig=sigma+(y>>2u)*mstr; u32* dpp=buf+y*sstr;\n"
"        if(height-y<4u){ row_pattern=0x7777u; if(height-y<3u){ row_pattern=0x3333u; if(height-y<2u) row_pattern=0x1111u; } }\n"
"        for(u32 x=0u;x<width;x+=4u,++cur_sig,++prev_sig){ u32 s=x+4u-width; u32 pattern=row_pattern>>((s<4u?s:0u)*4u);\n"
"          u32 ps=d_loadu32(prev_sig); u32 ns=d_loadu32(cur_sig+mstr); u32 u=(ps&0x88888888u)>>3u; u32 cs=d_loadu32(cur_sig); u32 mbr,t,new_sig;\n"
"          u|=(ns&0x11111111u)<<3u; mbr=cs; mbr|=(cs&0x77777777u)<<1u; mbr|=(cs&0xeeeeeeeeu)>>1u; mbr|=u; t=mbr; mbr|=t<<4u; mbr|=t>>4u; mbr|=prev>>12u; mbr&=pattern; mbr&=~cs; new_sig=mbr;\n"
"          if(new_sig){ u32 cwd=d_magsgn_fetch(&sigprop); u32 cnt=0u; u32 col_mask=0x0fu; u32 inv_sig=~cs&pattern;\n"
"            for(int bi=0;bi<16;bi+=4,col_mask<<=4u){ u32 sample_mask; if((col_mask&new_sig)==0u) continue;\n"
"              sample_mask=0x1111u&col_mask; if(new_sig&sample_mask){ new_sig&=~sample_mask; if(cwd&1u) new_sig|=(0x33u<<bi)&inv_sig; cwd>>=1u; ++cnt; }\n"
"              sample_mask<<=1u; if(new_sig&sample_mask){ new_sig&=~sample_mask; if(cwd&1u) new_sig|=(0x76u<<bi)&inv_sig; cwd>>=1u; ++cnt; }\n"
"              sample_mask<<=1u; if(new_sig&sample_mask){ new_sig&=~sample_mask; if(cwd&1u) new_sig|=(0xecu<<bi)&inv_sig; cwd>>=1u; ++cnt; }\n"
"              sample_mask<<=1u; if(new_sig&sample_mask){ new_sig&=~sample_mask; if(cwd&1u) new_sig|=(0xc8u<<bi)&inv_sig; cwd>>=1u; ++cnt; } }\n"
"            if(new_sig){ u32* rdp=dpp+x; u32 val=3u<<(p-2u); col_mask=0x0fu;\n"
"              for(int bi=0;bi<4;++bi,++rdp,col_mask<<=4u){ u32 sample_mask; if((col_mask&new_sig)==0u) continue;\n"
"                sample_mask=0x1111u&col_mask; if(new_sig&sample_mask){ rdp[0]=(cwd<<31u)|val; cwd>>=1u; ++cnt; }\n"
"                sample_mask<<=1u; if((new_sig&sample_mask)&&y+1u<height){ rdp[sstr]=(cwd<<31u)|val; cwd>>=1u; ++cnt; }\n"
"                sample_mask<<=1u; if((new_sig&sample_mask)&&y+2u<height){ rdp[2u*sstr]=(cwd<<31u)|val; cwd>>=1u; ++cnt; }\n"
"                sample_mask<<=1u; if((new_sig&sample_mask)&&y+3u<height){ rdp[3u*sstr]=(cwd<<31u)|val; cwd>>=1u; ++cnt; } } }\n"
"            d_magsgn_advance(&sigprop,cnt); }\n"
"          new_sig|=cs; *prev_sig=(u16)new_sig; t=new_sig; new_sig|=(t&0x7777u)<<1u; new_sig|=(t&0xeeeeu)>>1u; prev=(new_sig|u)&0xf000u;\n"
"        } } }\n"
"    if(num_passes>2u){ DVlc magref; if(!d_mrp_init(&magref, sd, lengths1, lengths2)) return;\n"
"      for(u32 y=0u;y<height;y+=4u){ u16* cur_sig=sigma+(y>>2u)*mstr; u32* dpp=buf+y*sstr; u32 half=1u<<(p-2u);\n"
"        for(u32 x=0u;x<width;x+=8u,cur_sig+=2u){ u32 cwd=d_mrp_fetch(&magref); u32 sig=d_loadu32(cur_sig); u32 col_mask=0x0fu;\n"
"          if(sig){ for(int j=0;j<8;++j,col_mask<<=4u){ u32 sample_mask; u32* rdp; if((sig&col_mask)==0u) continue; rdp=dpp+x+(u32)j; sample_mask=0x11111111u&col_mask;\n"
"            for(int k=0;k<4;++k){ if(sig&sample_mask){ u32 sym=cwd&1u; sym=(1u-sym)<<(p-1u); sym|=half; rdp[0]^=sym; cwd>>=1u; } sample_mask<<=1u; rdp+=sstr; } } }\n"
"          d_vlc_advance(&magref, d_popc(sig)); } } }\n"
"  }\n"
/* --- sign/magnitude -> signed coefficients into out tile --- */
"  { u32 y; u32 shift=(kmax<31u)?31u-kmax:0u; int* out=out_coeffs+rec.out_offset; u32 os=rec.out_stride;\n"
"    for(y=0u;y<height;++y){ const u32* brow=buf+(u64)y*sstr; int* orow=out+(u64)y*os; u32 x;\n"
"      for(x=0u;x<width;++x){ u32 vv=brow[x]; int mag=(int)((vv&0x7fffffffu)>>shift); orow[x]=(vv&0x80000000u)?-mag:mag; } } }\n"
"}\n"
/* ======================================================================== */
/* ===== ENCODE: HT block coder (scalar transcription of jph_encode_block) = */
/* ======================================================================== */
"struct JphGpuEncRec { u32 width,height,kmax,eligible; u64 coeff_offset; u64 out_offset; };\n"
"struct JphGpuEncOut { u32 missing, len0, size, pad; };\n"
"__device__ __forceinline__ int d_clz32e(u32 v){ return v? (int)__clz(v) : 32; }\n"
"__device__ __forceinline__ u64 d_mask64e(u32 n){ return n>=64u?~0ull:((1ull<<n)-1ull); }\n"
/* MagSgn forward bit writer (per-byte flush == bulk flush, byte-identical) */
"struct DMsE { u8*buf; u32 pos,cap; u64 acc; int nbits,max_bits; };\n"
"__device__ void d_mse_init(DMsE*m,u8*buf,u32 cap){ m->buf=buf; m->pos=0; m->cap=cap; m->acc=0; m->nbits=0; m->max_bits=8; }\n"
"__device__ int d_mse_flush(DMsE*m){\n"
"  while(m->nbits>=m->max_bits){\n"
"    if(m->max_bits==8){ u8 b=(u8)(m->acc&0xFFu); if(m->pos>=m->cap) return 0; m->buf[m->pos++]=b; m->acc>>=8; m->nbits-=8; if(b==0xFFu) m->max_bits=7; }\n"
"    else { u8 b=(u8)(m->acc&0x7Fu); if(m->pos>=m->cap) return 0; m->buf[m->pos++]=b; m->acc>>=7; m->nbits-=7; m->max_bits=8; }\n"
"  } return 1;\n"
"}\n"
"__device__ int d_mse_encode64(DMsE*m,u64 cwd,int cwd_len){\n"
"  while(cwd_len>0){ int take=64-m->nbits; if(take>cwd_len) take=cwd_len;\n"
"    m->acc|=(cwd&(take<64?((1ull<<take)-1u):~0ull))<<m->nbits; m->nbits+=take; cwd>>=take; cwd_len-=take;\n"
"    if(!d_mse_flush(m)) return 0; } return 1;\n"
"}\n"
"__device__ int d_mse_terminate(DMsE*m){\n"
"  if(m->nbits){ int t=m->max_bits-m->nbits; u32 tmp=(u32)(m->acc&0xFFu); tmp|=(0xFFu&((1u<<t)-1u))<<m->nbits;\n"
"    if(tmp!=0xFFu){ if(m->pos>=m->cap) return 0; m->buf[m->pos++]=(u8)tmp; } }\n"
"  else if(m->max_bits==7 && m->pos>0u){ m->pos--; } return 1;\n"
"}\n"
/* MEL encoder */
"struct DMelE { u8*buf; u32 pos,cap; int remaining_bits,tmp,run,k,threshold; };\n"
"__device__ void d_mele_init(DMelE*m,u8*buf,u32 cap){ m->buf=buf; m->pos=0; m->cap=cap; m->remaining_bits=8; m->tmp=0; m->run=0; m->k=0; m->threshold=1; }\n"
"__device__ int d_mele_emit(DMelE*m,int v){ m->tmp=(m->tmp<<1)+v; m->remaining_bits--; if(m->remaining_bits==0){ if(m->pos>=m->cap) return 0; m->buf[m->pos++]=(u8)m->tmp; m->remaining_bits=(m->tmp==0xFF)?7:8; m->tmp=0; } return 1; }\n"
"__device__ int d_mele_encode(DMelE*m,int bit){ const int mel_exp[13]={0,0,0,1,1,1,2,2,2,3,3,4,5};\n"
"  if(bit==0){ ++m->run; if(m->run>=m->threshold){ if(!d_mele_emit(m,1)) return 0; m->run=0; m->k=(m->k<12)?m->k+1:12; m->threshold=1<<mel_exp[m->k]; } }\n"
"  else { if(!d_mele_emit(m,0)) return 0; int t=mel_exp[m->k]; while(t>0){ t--; if(!d_mele_emit(m,(m->run>>t)&1)) return 0; } m->run=0; m->k=(m->k>0)?m->k-1:0; m->threshold=1<<mel_exp[m->k]; } return 1;\n"
"}\n"
/* VLC encoder (backward-growing into slab[cap-1-pos]) */
"struct DVlcE { u8*slab; u32 pos,cap; int used_bits; u64 tmp; int last; };\n"
"__device__ void d_vlce_init(DVlcE*v,u8*slab,u32 cap){ v->slab=slab; v->cap=cap; v->pos=1; v->slab[cap-1]=0xFF; v->used_bits=4; v->tmp=0xF; v->last=1; }\n"
"__device__ int d_vlce_encode(DVlcE*v,int cwd,int cwd_len){\n"
"  if(cwd_len<=0) return 1; v->tmp|=(u64)(u32)cwd<<v->used_bits; v->used_bits+=cwd_len;\n"
"  while(v->used_bits>=8){ u8 b; if(v->pos>=v->cap) return 0;\n"
"    if(v->last){ b=(u8)(v->tmp&0x7Fu); if(b!=0x7Fu){ b=(u8)(v->tmp&0xFFu); v->slab[v->cap-1-v->pos]=b; v->pos++; v->last=(b>0x8Fu)?1:0; v->tmp>>=8; v->used_bits-=8; }\n"
"      else { v->slab[v->cap-1-v->pos]=b; v->pos++; v->last=0; v->tmp>>=7; v->used_bits-=7; } }\n"
"    else { b=(u8)(v->tmp&0xFFu); v->slab[v->cap-1-v->pos]=b; v->pos++; v->last=(b>0x8Fu)?1:0; v->tmp>>=8; v->used_bits-=8; } } return 1;\n"
"}\n"
"__device__ int d_mel_vlc_terminate(DMelE*m,DVlcE*v){\n"
"  if(m->run>0){ if(!d_mele_emit(m,1)) return 0; }\n"
"  m->tmp=m->tmp<<m->remaining_bits; int mel_mask=(0xFF<<m->remaining_bits)&0xFF; int vlc_mask=0xFF>>(8-v->used_bits);\n"
"  if((mel_mask|vlc_mask)==0) return 1; if(m->pos>=m->cap) return 0;\n"
"  int vtmp=(int)(v->tmp&0xFFu); int fuse=m->tmp|vtmp;\n"
"  if(((((fuse^m->tmp)&mel_mask)|((fuse^vtmp)&vlc_mask))==0)&&(fuse!=0xFF)&&v->pos>1){ m->buf[m->pos++]=(u8)fuse; }\n"
"  else { if(v->pos>=v->cap) return 0; m->buf[m->pos++]=(u8)m->tmp; v->slab[v->cap-1-v->pos]=(u8)vtmp; v->pos++; } return 1;\n"
"}\n"
/* prepare one sample from int32 plane (== jph_encode_block_prepare_sample_from32) */
"__device__ void d_enc_prep(const int* pl,u32 stride,u32 x,u32 y,u32 shift,u32 p,int* rho,int* e_qmax,int* e_q,u64* s,int bit,u64* max_val){\n"
"  int sv=pl[(u64)y*stride+x]; u32 mask=(u32)(sv>>31); u32 mag=((u32)sv^mask)-mask;\n"
"  if(mag>*(u32*)0){} if((u64)mag>*max_val) *max_val=(u64)mag;\n"
"  u32 t=(sv<0?0x80000000u:0u)|(mag<<shift); u32 val=t+t; val>>=p; val&=~1u;\n"
"  if(val){ int eq; *rho|=bit; --val; eq=32-d_clz32e(val); *e_q=eq; if(eq>*e_qmax) *e_qmax=eq; --val; *s=(u64)(val+(t>>31u)); } else { *e_q=0; *s=0; }\n"
"}\n"
/* uvlc enc table packed as u8[i*6 + {pre,pre_len,suf,suf_len,ext,ext_len}] */
"__device__ int d_enc_uvlc_pair(DVlcE*vlc,const u8* ut,int u_q0,int u_q1,int initial){\n"
"  if(u_q0<0||u_q1<0||u_q0>=75||u_q1>=75) return 0;\n"
"  if(initial&&u_q0>0&&u_q1>0){\n"
"    if(u_q0>2&&u_q1>2){ int a=u_q0-2,b=u_q1-2; if(a>=75||b>=75) return 0;\n"
"      if(!d_vlce_encode(vlc,ut[a*6+0],ut[a*6+1])) return 0; if(!d_vlce_encode(vlc,ut[b*6+0],ut[b*6+1])) return 0;\n"
"      if(!d_vlce_encode(vlc,ut[a*6+2],ut[a*6+3])) return 0; if(!d_vlce_encode(vlc,ut[b*6+2],ut[b*6+3])) return 0;\n"
"      if(!d_vlce_encode(vlc,ut[a*6+4],ut[a*6+5])) return 0; return d_vlce_encode(vlc,ut[b*6+4],ut[b*6+5]); }\n"
"    if(u_q0>2){ if(!d_vlce_encode(vlc,ut[u_q0*6+0],ut[u_q0*6+1])) return 0; if(!d_vlce_encode(vlc,(u_q1-1),1)) return 0;\n"
"      if(!d_vlce_encode(vlc,ut[u_q0*6+2],ut[u_q0*6+3])) return 0; return d_vlce_encode(vlc,ut[u_q0*6+4],ut[u_q0*6+5]); } }\n"
"  if(!d_vlce_encode(vlc,ut[u_q0*6+0],ut[u_q0*6+1])) return 0; if(!d_vlce_encode(vlc,ut[u_q1*6+0],ut[u_q1*6+1])) return 0;\n"
"  if(!d_vlce_encode(vlc,ut[u_q0*6+2],ut[u_q0*6+3])) return 0; if(!d_vlce_encode(vlc,ut[u_q1*6+2],ut[u_q1*6+3])) return 0;\n"
"  if(!d_vlce_encode(vlc,ut[u_q0*6+4],ut[u_q0*6+5])) return 0; return d_vlce_encode(vlc,ut[u_q1*6+4],ut[u_q1*6+5]);\n"
"}\n"
"__device__ int d_enc_mag_pair(DMsE*ms,u64 s0,u64 s1,int rho,int bit0,int bit1,int Uq,u32 tuple){\n"
"  int m0=(rho&bit0)?Uq-((tuple&bit0)?1:0):0; int m1=(rho&bit1)?Uq-((tuple&bit1)?1:0):0; u64 cwd; int L;\n"
"  if(m0<0||m1<0||m0>=64||m1>=64) return 0; if((m0|m1)==0) return 1;\n"
"  if(m0==0) return d_mse_encode64(ms,s1&d_mask64e((u32)m1),m1);\n"
"  if(m1==0) return d_mse_encode64(ms,s0&d_mask64e((u32)m0),m0);\n"
"  L=m0+m1; if(L<64){ cwd=s0&d_mask64e((u32)m0); cwd|=(s1&d_mask64e((u32)m1))<<(u32)m0; return d_mse_encode64(ms,cwd,L); }\n"
"  if(!d_mse_encode64(ms,s0&d_mask64e((u32)m0),m0)) return 0; return d_mse_encode64(ms,s1&d_mask64e((u32)m1),m1);\n"
"}\n"
"__device__ int d_enc_mag_quad(DMsE*ms,const u64* s,int rho,int Uq,u32 tuple){\n"
"  if(!d_enc_mag_pair(ms,s[0],s[1],rho,1,2,Uq,tuple)) return 0; return d_enc_mag_pair(ms,s[2],s[3],rho,4,8,Uq,tuple);\n"
"}\n"
"extern \"C\" __global__ void exrg_jph_encode_blocks(\n"
"    const int* coeffs, const JphGpuEncRec* recs, int num_recs,\n"
"    const u16* venc0, const u16* venc1, const u8* uenc,\n"
"    u8* out_all, u32 out_stride, JphGpuEncOut* outs,\n"
"    u8* ms_all, u32 ms_stride, u8* mel_all, u32 mel_stride, u8* vlc_all, u32 vlc_stride){\n"
"  int tid=blockIdx.x*blockDim.x+threadIdx.x; if(tid>=num_recs) return;\n"
"  JphGpuEncRec rec=recs[tid]; if(!rec.eligible) return;\n"
"  outs[tid].missing=rec.kmax; outs[tid].len0=0; outs[tid].size=0; outs[tid].pad=0;\n"
"  u32 kmax=rec.kmax; if(kmax==0u||kmax>30u) return;\n"
"  const int* pl=coeffs+rec.coeff_offset; u32 stride=rec.width; u32 width=rec.width, height=rec.height;\n"
"  u32 p=31u-kmax, shift=p; u64 max_val=0;\n"
"  DMsE ms; d_mse_init(&ms, ms_all+(u64)tid*ms_stride, ms_stride);\n"
"  DMelE mel; d_mele_init(&mel, mel_all+(u64)tid*mel_stride, mel_stride);\n"
"  DVlcE vlc; d_vlce_init(&vlc, vlc_all+(u64)tid*vlc_stride, vlc_stride);\n"
"  unsigned char e_val[513]; unsigned char cx_val[513];\n"
"  for(int z=0;z<513;++z){ e_val[z]=0; cx_val[z]=0; }\n"
"  unsigned char* lep=e_val; unsigned char* lcxp=cx_val; int c_q0=0;\n"
/* initial row of quads (y=0) */
"  { u32 x; int e_qmax[2],e_q[8],rho[2]; u64 s[8];\n"
"    for(x=0u;x<width;x+=4u){ int Uq0,Uq1=1,u_q0,u_q1=0,eps0=0,eps1=0,c_q1; u32 tuple0,tuple1=0;\n"
"      rho[0]=rho[1]=0; e_qmax[0]=e_qmax[1]=0;\n"
"      d_enc_prep(pl,stride,x,0u,shift,p,&rho[0],&e_qmax[0],&e_q[0],&s[0],1,&max_val);\n"
"      if(height>1u) d_enc_prep(pl,stride,x,1u,shift,p,&rho[0],&e_qmax[0],&e_q[1],&s[1],2,&max_val); else { e_q[1]=0; s[1]=0; }\n"
"      if(x+1u<width){ d_enc_prep(pl,stride,x+1u,0u,shift,p,&rho[0],&e_qmax[0],&e_q[2],&s[2],4,&max_val);\n"
"        if(height>1u) d_enc_prep(pl,stride,x+1u,1u,shift,p,&rho[0],&e_qmax[0],&e_q[3],&s[3],8,&max_val); else { e_q[3]=0; s[3]=0; } } else { e_q[2]=0; s[2]=0; e_q[3]=0; s[3]=0; }\n"
"      Uq0=e_qmax[0]>1?e_qmax[0]:1; u_q0=Uq0-1;\n"
"      if(u_q0>0){ eps0|=(e_q[0]==e_qmax[0]); eps0|=(e_q[1]==e_qmax[0])<<1; eps0|=(e_q[2]==e_qmax[0])<<2; eps0|=(e_q[3]==e_qmax[0])<<3; }\n"
"      lep[0]=lep[0]>(unsigned char)e_q[1]?lep[0]:(unsigned char)e_q[1]; lep++; lep[0]=(unsigned char)e_q[3];\n"
"      lcxp[0]=(unsigned char)(lcxp[0]|(unsigned char)((rho[0]&2)>>1)); lcxp++; lcxp[0]=(unsigned char)((rho[0]&8)>>3);\n"
"      tuple0=venc0[(c_q0<<8)+(rho[0]<<4)+eps0]; if(!d_vlce_encode(&vlc,tuple0>>8,(tuple0>>4)&7)) return;\n"
"      if(c_q0==0){ if(!d_mele_encode(&mel,rho[0]!=0)) return; }\n"
"      if(!d_enc_mag_quad(&ms,&s[0],rho[0],Uq0,tuple0)) return;\n"
"      if(x+2u<width){\n"
"        d_enc_prep(pl,stride,x+2u,0u,shift,p,&rho[1],&e_qmax[1],&e_q[4],&s[4],1,&max_val);\n"
"        if(height>1u) d_enc_prep(pl,stride,x+2u,1u,shift,p,&rho[1],&e_qmax[1],&e_q[5],&s[5],2,&max_val); else { e_q[5]=0; s[5]=0; }\n"
"        if(x+3u<width){ d_enc_prep(pl,stride,x+3u,0u,shift,p,&rho[1],&e_qmax[1],&e_q[6],&s[6],4,&max_val);\n"
"          if(height>1u) d_enc_prep(pl,stride,x+3u,1u,shift,p,&rho[1],&e_qmax[1],&e_q[7],&s[7],8,&max_val); else { e_q[7]=0; s[7]=0; } } else { e_q[6]=0; s[6]=0; e_q[7]=0; s[7]=0; }\n"
"        c_q1=(rho[0]>>1)|(rho[0]&1); Uq1=e_qmax[1]>1?e_qmax[1]:1; u_q1=Uq1-1;\n"
"        if(u_q1>0){ eps1|=(e_q[4]==e_qmax[1]); eps1|=(e_q[5]==e_qmax[1])<<1; eps1|=(e_q[6]==e_qmax[1])<<2; eps1|=(e_q[7]==e_qmax[1])<<3; }\n"
"        lep[0]=lep[0]>(unsigned char)e_q[5]?lep[0]:(unsigned char)e_q[5]; lep++; lep[0]=(unsigned char)e_q[7];\n"
"        lcxp[0]=(unsigned char)(lcxp[0]|(unsigned char)((rho[1]&2)>>1)); lcxp++; lcxp[0]=(unsigned char)((rho[1]&8)>>3);\n"
"        tuple1=venc0[(c_q1<<8)+(rho[1]<<4)+eps1]; if(!d_vlce_encode(&vlc,tuple1>>8,(tuple1>>4)&7)) return;\n"
"        if(c_q1==0){ if(!d_mele_encode(&mel,rho[1]!=0)) return; }\n"
"        if(!d_enc_mag_quad(&ms,&s[4],rho[1],Uq1,tuple1)) return;\n"
"      }\n"
"      if(u_q0>0&&u_q1>0){ int mn=u_q0<u_q1?u_q0:u_q1; if(!d_mele_encode(&mel,mn>2)) return; }\n"
"      if(!d_enc_uvlc_pair(&vlc,uenc,u_q0,u_q1,1)) return; c_q0=(rho[1]>>1)|(rho[1]&1);\n"
"    } }\n"
"  lep[1]=0;\n"
/* non-initial rows */
"  for(u32 y=2u;y<height;y+=2u){ int max_e; lep=e_val; max_e=(lep[0]>lep[1]?lep[0]:lep[1])-1; lep[0]=0; lcxp=cx_val; c_q0=lcxp[0]+(lcxp[1]<<2); lcxp[0]=0;\n"
"    for(u32 x=0u;x<width;x+=4u){ int e_qmax[2]={0,0},e_q[8]={0,0,0,0,0,0,0,0},rho[2]={0,0}; u64 s[8]={0,0,0,0,0,0,0,0};\n"
"      int kappa,Uq0,Uq1=1,u_q0,u_q1=0,eps0=0,eps1=0,c_q1; u32 tuple0,tuple1=0;\n"
"      d_enc_prep(pl,stride,x,y,shift,p,&rho[0],&e_qmax[0],&e_q[0],&s[0],1,&max_val);\n"
"      if(y+1u<height) d_enc_prep(pl,stride,x,y+1u,shift,p,&rho[0],&e_qmax[0],&e_q[1],&s[1],2,&max_val); else { e_q[1]=0; s[1]=0; }\n"
"      if(x+1u<width){ d_enc_prep(pl,stride,x+1u,y,shift,p,&rho[0],&e_qmax[0],&e_q[2],&s[2],4,&max_val);\n"
"        if(y+1u<height) d_enc_prep(pl,stride,x+1u,y+1u,shift,p,&rho[0],&e_qmax[0],&e_q[3],&s[3],8,&max_val); else { e_q[3]=0; s[3]=0; } } else { e_q[2]=0; s[2]=0; e_q[3]=0; s[3]=0; }\n"
"      kappa=(rho[0]&(rho[0]-1))?(max_e>1?max_e:1):1; Uq0=e_qmax[0]>kappa?e_qmax[0]:kappa; u_q0=Uq0-kappa;\n"
"      if(u_q0>0){ eps0|=(e_q[0]==e_qmax[0]); eps0|=(e_q[1]==e_qmax[0])<<1; eps0|=(e_q[2]==e_qmax[0])<<2; eps0|=(e_q[3]==e_qmax[0])<<3; }\n"
"      lep[0]=lep[0]>(unsigned char)e_q[1]?lep[0]:(unsigned char)e_q[1]; lep++; max_e=(lep[0]>lep[1]?lep[0]:lep[1])-1; lep[0]=(unsigned char)e_q[3];\n"
"      lcxp[0]=(unsigned char)(lcxp[0]|(unsigned char)((rho[0]&2)>>1)); lcxp++; c_q1=lcxp[0]+(lcxp[1]<<2); lcxp[0]=(unsigned char)((rho[0]&8)>>3);\n"
"      tuple0=venc1[(c_q0<<8)+(rho[0]<<4)+eps0]; if(!d_vlce_encode(&vlc,tuple0>>8,(tuple0>>4)&7)) return;\n"
"      if(c_q0==0){ if(!d_mele_encode(&mel,rho[0]!=0)) return; }\n"
"      if(!d_enc_mag_quad(&ms,&s[0],rho[0],Uq0,tuple0)) return;\n"
"      if(x+2u<width){\n"
"        d_enc_prep(pl,stride,x+2u,y,shift,p,&rho[1],&e_qmax[1],&e_q[4],&s[4],1,&max_val);\n"
"        if(y+1u<height) d_enc_prep(pl,stride,x+2u,y+1u,shift,p,&rho[1],&e_qmax[1],&e_q[5],&s[5],2,&max_val); else { e_q[5]=0; s[5]=0; }\n"
"        if(x+3u<width){ d_enc_prep(pl,stride,x+3u,y,shift,p,&rho[1],&e_qmax[1],&e_q[6],&s[6],4,&max_val);\n"
"          if(y+1u<height) d_enc_prep(pl,stride,x+3u,y+1u,shift,p,&rho[1],&e_qmax[1],&e_q[7],&s[7],8,&max_val); else { e_q[7]=0; s[7]=0; } } else { e_q[6]=0; s[6]=0; e_q[7]=0; s[7]=0; }\n"
"        kappa=(rho[1]&(rho[1]-1))?(max_e>1?max_e:1):1; c_q1|=((rho[0]&4)>>1)|((rho[0]&8)>>2); Uq1=e_qmax[1]>kappa?e_qmax[1]:kappa; u_q1=Uq1-kappa;\n"
"        if(u_q1>0){ eps1|=(e_q[4]==e_qmax[1]); eps1|=(e_q[5]==e_qmax[1])<<1; eps1|=(e_q[6]==e_qmax[1])<<2; eps1|=(e_q[7]==e_qmax[1])<<3; }\n"
"        lep[0]=lep[0]>(unsigned char)e_q[5]?lep[0]:(unsigned char)e_q[5]; lep++; max_e=(lep[0]>lep[1]?lep[0]:lep[1])-1; lep[0]=(unsigned char)e_q[7];\n"
"        lcxp[0]=(unsigned char)(lcxp[0]|(unsigned char)((rho[1]&2)>>1)); lcxp++; c_q0=lcxp[0]+(lcxp[1]<<2); lcxp[0]=(unsigned char)((rho[1]&8)>>3);\n"
"        tuple1=venc1[(c_q1<<8)+(rho[1]<<4)+eps1]; if(!d_vlce_encode(&vlc,tuple1>>8,(tuple1>>4)&7)) return;\n"
"        if(c_q1==0){ if(!d_mele_encode(&mel,rho[1]!=0)) return; }\n"
"        if(!d_enc_mag_quad(&ms,&s[4],rho[1],Uq1,tuple1)) return;\n"
"      }\n"
"      if(!d_enc_uvlc_pair(&vlc,uenc,u_q0,u_q1,0)) return; c_q0|=((rho[1]&4)>>1)|((rho[1]&8)>>2);\n"
"    } }\n"
/* finalize + assemble */
"  if(max_val==0){ outs[tid].missing=kmax; outs[tid].len0=0; outs[tid].size=0; return; }\n"
"  if(max_val>=(1ull<<kmax)) return;\n"
"  if(!d_mse_terminate(&ms)) return; if(!d_mel_vlc_terminate(&mel,&vlc)) return;\n"
"  { int lcup=(int)ms.pos+(int)mel.pos+(int)vlc.pos; int scup=(int)mel.pos+(int)vlc.pos;\n"
"    if(lcup<2){ lcup=2; scup=2; } if(lcup>(int)out_stride) return;\n"
"    u8* out=out_all+(u64)tid*out_stride;\n"
"    for(u32 i=0;i<ms.pos;++i) out[i]=ms.buf[i];\n"
"    for(u32 i=0;i<mel.pos;++i) out[ms.pos+i]=mel.buf[i];\n"
"    for(u32 i=0;i<vlc.pos;++i) out[ms.pos+mel.pos+i]=vlc.slab[vlc.cap-vlc.pos+i];\n"
"    out[lcup-2]=(u8)((out[lcup-2]&0xF0)|(scup&0x0F)); out[lcup-1]=(u8)((scup>>4)&0xFF);\n"
"    outs[tid].missing=(kmax-1u); outs[tid].len0=(u32)lcup; outs[tid].size=(u32)lcup; }\n"
"}\n";
