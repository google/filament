material {
    name : baked_color,
    parameters : [
        {
            type : float,
            name : targetFps
        }
    ],
    shadingModel : unlit,
    featureLevel : 0
}

vertex {
    void materialVertex(inout MaterialVertexInputs material) {
        // we don't floor() on purpose here to demonstrate we have a solid time base
        // thanks to resetUserTime(vsync)
        float frameCount = getUserTime().x * materialParams.targetFps;
        // 7 frames per revolution
        float t = frameCount * (6.2831853 / 7.0);
        float c = cos(t);
        float s = sin(t);
        vec3 p = material.worldPosition.xyz;
        material.worldPosition.x = p.x * c - p.y * s;
        material.worldPosition.y = p.x * s + p.y * c;
    }
}

fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        float frameCount = floor(getUserTime().x * materialParams.targetFps + 0.5);
        // 7 rainbow colors (ROYGBIV)
        float idx = mod(frameCount, 7.0);
        vec3 handColor = vec3(1.0, 0.0, 0.0);
        if (idx > 0.5) handColor = vec3(1.0, 0.5, 0.0);
        if (idx > 1.5) handColor = vec3(1.0, 1.0, 0.0);
        if (idx > 2.5) handColor = vec3(0.0, 1.0, 0.0);
        if (idx > 3.5) handColor = vec3(0.0, 0.0, 1.0);
        if (idx > 4.5) handColor = vec3(0.29, 0.0, 0.51);
        if (idx > 5.5) handColor = vec3(0.56, 0.0, 1.0);
        material.baseColor = vec4(handColor, 1.0);
    }
}
