{
  "name": "Default Test",
  "backends": [
    "opengl",
    "vulkan"
  ],
  "models": {
    "DamagedHelmet": "helmet.glb"
  },
  "presets": [
    {
      "name": "base",
      "models": [
        "DamagedHelmet"
      ],
      "rendering": {
        "camera": {
          "enabled": true,
          "horizontalFov": 45.0,
          "center": [
            0,
            0,
            0
          ],
          "lookAt": [
            0,
            0,
            -1
          ]
        },
        "view": {
          "postProcessingEnabled": true,
          "dithering": "NONE"
        }
      },
      "tolerance": {
        "mode": "OR",
        "maxFailingPixelsFraction": 0.0005,
        "children": [
          // Scenario: Geometry rasterization snapping differences between different GPU architectures (e.g., Adreno versions).
          // Method: Allow a 1-pixel positional shift but demand a very strict color match.
          {
            "maxAbsDiff": 0.02,
            "shiftRadius": 1,
            "blurRadius": 0
          },
          // Scenario: Floating-point math precision differences in shaders across architectures.
          // Method: Demand exact pixel position but allow a slightly looser color precision variance.
          {
            "maxAbsDiff": 0.05,
            "shiftRadius": 0,
            "blurRadius": 0
          }
        ]
      }
    },
    {
      "name": "tilted",
      "rendering": {
        "camera": {
          "enabled": true,
          "horizontalFov": 45.0,
          "center": [
            -4,
            -2,
            -3
          ],
          "lookAt": [
            0,
            0,
            -4
          ]
        }
      }
    },
    {
      "name": "relaxed_tolerance",
      // Scenario: Screen Space Reflections (SSR) stochastic raymarching noise.
      // Method: Apply a 7x7 low-pass filter (blurRadius: 3) to smooth out high-frequency noise,
      // allow slight reflection warping (shiftRadius: 2), and strictly check the smoothed underlying color.
      "tolerance": {
        "maxAbsDiff": 0.09,
        "shiftRadius": 2,
        "blurRadius": 3,
        "maxFailingPixelsFraction": 0.0005
      },
      "rendering": {}
    },
    {
      "name": "noisy_tolerance",
      "rendering": {},
      "tolerance": {
        "mode": "OR",
        "maxFailingPixelsFraction": 0.0005,
        "children": [
          // Scenario: Bloom & MSAA edge jitter caused by slightly different sub-pixel sampling patterns.
          // Method: Allow a 1-pixel positional shift with a moderate color variance.
          {
            "maxAbsDiff": 0.05,
            "shiftRadius": 1,
            "blurRadius": 0
          },
          // Scenario: High-frequency noise generated by noisy post-processing effects.
          // Method: Apply a 5x5 low-pass filter (blurRadius: 2) to smooth the noise, demanding exact position and strict color match.
          {
            "maxAbsDiff": 0.05,
            "shiftRadius": 0,
            "blurRadius": 2
          }
        ]
      }
    }
  ],
  "tests": [
    {
      "name": "basic",
      "apply_presets": [
        "base"
      ]
    },
    {
      "name": "rotated",
      "apply_presets": [
        "base",
        "tilted"
      ]
    },
    {
      "name": "msaa_custom",
      "apply_presets": [
        "base",
        "noisy_tolerance"
      ],
      "rendering": {
        "view.msaa.enabled": true,
        "view.msaa.customResolve": true
      }
    },
    {
      "name": "msaa_standard",
      "apply_presets": [
        "base",
        "noisy_tolerance"
      ],
      "rendering": {
        "view.msaa.enabled": true,
        "view.msaa.customResolve": false
      }
    },
    {
      "name": "msaa_8",
      "apply_presets": [
        "base",
        "noisy_tolerance"
      ],
      "rendering": {
        "view.msaa.enabled": true,
        "view.msaa.sampleCount": 8
      }
    },
    {
      "name": "fxaa",
      "apply_presets": [
        "base",
        "noisy_tolerance"
      ],
      "rendering": {
        "view.antiAliasing": "FXAA"
      }
    },
    {
      "name": "ssao_gtao",
      "apply_presets": [
